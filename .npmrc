# The legacy gulp/rollup pipeline pins React 17 (admin/src). The modern @wordpress/scripts
# pipeline (admin/src-modern) targets WordPress core's React 18 (wp-element) and externalizes
# React at build time, so its React-18 peer range is satisfied by WordPress at runtime, not by
# this project's React 17 dependency. Allow the two pipelines to coexist in one install tree.
legacy-peer-deps=true
